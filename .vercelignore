# Anything in here is excluded from the upload to Vercel (in addition to
# what .gitignore already handles). Belt-and-suspenders against shipping
# dev junk.
#
# IMPORTANT: this file affects what gets *uploaded to Vercel* for the
# build, NOT what ends up in the serverless function bundle. The function
# bundle is controlled separately by `functions.<file>.includeFiles` in
# vercel.json. So don't ignore frontend/ stuff here -- Vercel needs it to
# run `npm install && npm run build`. The function only includes
# backend/app/** per vercel.json.

# Local Python virtualenvs
.venv
**/.venv
venv

# Python build / test cache
**/__pycache__
**/*.pyc
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
*.egg-info

# Local databases
*.db
*.sqlite
*.sqlite3

# Local env files (never ship secrets)
.env
.env.local
backend/.env
backend/.env.local
frontend/.env
frontend/.env.local

# Frontend build output: Vercel rebuilds it; uploading it just wastes time
frontend/dist
frontend/node_modules

# Misc dev / repo metadata
.git
node_modules
RECAP.md
README.dev.md
