{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'install handled per-target'",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3.1",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "backend/app/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/docs", "destination": "/api/index.py" },
    { "source": "/redoc", "destination": "/api/index.py" },
    { "source": "/openapi.json", "destination": "/api/index.py" }
  ]
}
