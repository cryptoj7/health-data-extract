# Copy to .env and edit. NEVER commit a real .env file.

# App
ENVIRONMENT=development
DEBUG=true

# Database
# - Default: local SQLite (zero-setup)
# - Local Postgres via docker-compose (recommended for parity with prod):
#     docker compose up -d postgres
#     -> DATABASE_URL=postgresql+psycopg://hde:hde@localhost:5433/health_data
# - Production: set to your hosted Postgres URL (Vercel Postgres / Neon / Supabase / RDS)
DATABASE_URL=sqlite:///./health_data.db
# DATABASE_URL=postgresql+psycopg://hde:hde@localhost:5433/health_data
# DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/DB?sslmode=require

# Auth
REQUIRE_AUTH=true
API_KEY=dev-api-key-change-me

# CORS (comma-separated origins, or "*" for any)
CORS_ORIGINS=*

# Rate limits (slowapi syntax)
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_UPLOAD=10/minute

# Uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME_TYPES=application/pdf

# OpenAI (optional but strongly recommended for accurate extraction)
OPENAI_API_KEY=
# GPT-5.4 (released 2026-03-05) is the default — frontier multimodal model that
# accepts images up to 10M pixels uncompressed (much better for scanned medical PDFs
# where small text matters). For lower cost / faster turnaround, use "gpt-5.4-mini".
OPENAI_MODEL=gpt-5.4
# Reasoning effort for GPT-5.x / o-series. "low" is the sweet spot for OCR-style
# extraction; bump to "medium" for very noisy or handwritten scans. Ignored on
# non-reasoning models like gpt-4o-mini.
OPENAI_REASONING_EFFORT=low
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=2
